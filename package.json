{
  "name": "tidewell-admin-panel",
  "private": true,
  "version": "0.3.2",
  "type": "module",
  "bin": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "package": "npm run build && esbuild server.js --bundle --platform=node --format=cjs --external:express --outfile=server.cjs && node scripts/package-exe.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "@yao-pkg/pkg": "^5.12.0",
    "esbuild": "^0.28.1",
    "vite": "^5.4.0"
  },
  "pkg": {
    "assets": [
      "dist/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "release"
  }
}
